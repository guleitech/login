# 环境变量示例文件
# 请复制此文件为 .env.local 并填写实际值

# Cloudflare 账户 ID
CF_ACCOUNT_ID=your_account_id_here

# Cloudflare D1 数据库 ID
CF_D1_DATABASE_ID=your_database_id_here

# Cloudflare API Token（用于 wrangler 命令）
CF_API_TOKEN=your_api_token_here

# JWT 密钥（用于生成和验证 JWT Token）
JWT_SECRET=your_jwt_secret_here_at_least_32_characters_long